name: Alerta Discord

on:
  push:
    branches:
      - main

jobs:
  enviar-alerta:
    runs-on: ubuntu-latest

    steps:
      - name: Enviar mensagem pro Discord
run: |
  curl -H "Content-Type: application/json" \
  -d "{\"content\":\"🚀 Commit realizado no repositório ${{ github.repository }} por ${{ github.actor }}\"}" \
  ${{ secrets.DISCORD_WEBHOOK }}